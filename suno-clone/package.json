{
  "name": "react_repo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "tsc -b && vite build --mode prod",
    "lint": "eslint .",
    "preview": "vite preview",
    "install-deps": "pnpm install --prefer-offline",
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['node_modules','.pnpm-store']) fs.rmSync(p,{recursive:true,force:true});\" && pnpm store prune"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@supabase/supabase-js": "^2.110.2",
    "lucide-react": "^0.364.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "10.5.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vite-plugin-source-identifier": "1.1.2"
  }
}
